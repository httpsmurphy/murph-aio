{
  "manifest_version": 3,
  "name": "Murph AIO",
  "version": "1.0.0",
  "description": "Murph AIO - Very checkout automation",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "webNavigation",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "https://www.very.co.uk/*",
    "https://very.co.uk/*",
    "https://discord.com/api/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Murph AIO",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.very.co.uk/*", "https://very.co.uk/*"],
      "js": ["src/very-content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.very.co.uk/*", "https://very.co.uk/*"],
      "js": ["src/very_tracker.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/murphy.png"],
      "matches": ["https://www.very.co.uk/*", "https://very.co.uk/*"]
    }
  ]
}
